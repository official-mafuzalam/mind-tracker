<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Dark theme overrides -->
    <style name="Base.Theme.MindTracker" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <!-- Primary colors (can keep same or adjust for dark) -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryContainer">@color/purple_900</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/purple_100</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/green_500</item>
        <item name="colorSecondaryContainer">@color/green_900</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorOnSecondaryContainer">@color/green_100</item>

        <!-- Surface colors - darker for night mode -->
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/grey_300</item>

        <!-- Background -->
        <item name="android:background">@color/surface_dark</item>

        <!-- Status bar - dark mode -->
        <item name="android:statusBarColor">@color/purple_900</item>
        <item name="android:windowLightStatusBar">@bool/window_light_status_bar_night</item>

        <!-- Navigation bar - dark mode -->
        <item name="android:navigationBarColor">@color/purple_900</item>
        <item name="android:windowLightNavigationBar">@bool/window_light_navigation_bar_night</item>

        <!-- Handle cutouts properly -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.MindTracker" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Brand colors -->
        <item name="colorPrimary">@color/purple_900</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/green_500</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">?attr/colorPrimary</item>
        <item name="android:windowLightNavigationBar">false</item>

    </style>

</resources>