<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="How are you feeling today?"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTodayMood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Custom Mood Buttons -->
        <com.octosync.mindtracker.MoodButton
            android:id="@+id/btnHappy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="😊 Happy"
            app:icon="@drawable/ic_mood"
            app:iconGravity="textStart" />

        <com.octosync.mindtracker.MoodButton
            android:id="@+id/btnNeutral"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="😐 Neutral"
            app:icon="@drawable/ic_mood" />

        <com.octosync.mindtracker.MoodButton
            android:id="@+id/btnSad"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="😔 Sad"
            app:icon="@drawable/ic_mood" />

        <com.octosync.mindtracker.MoodButton
            android:id="@+id/btnAngry"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="😡 Angry"
            app:icon="@drawable/ic_mood" />

        <com.octosync.mindtracker.MoodButton
            android:id="@+id/btnTired"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="😴 Tired"
            app:icon="@drawable/ic_mood" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdateMood"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Update Today's Mood"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStats"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="View Statistics" />

    </LinearLayout>
</ScrollView>